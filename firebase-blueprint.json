{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "Attendee registration record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "npa": { "type": "string" },
        "category": { "type": "string" },
        "categoryId": { "type": "string" },
        "branchId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "settlement", "capture", "expire", "cancel", "deny"] },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "category", "status"]
    },
    "Branch": {
      "title": "Branch",
      "description": "IDI Branch office",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "Membership category and price",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price"]
    },
    "Event": {
      "title": "Event",
      "description": "Information about a conference or meeting",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "isActive": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "categories": { 
          "type": "array",
          "items": { "type": "object" } 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startDate", "endDate", "isActive"]
    }
  },
  "firestore": {
    "registrations/{id}": {
      "schema": "Registration",
      "description": "Collection of event registrations"
    },
    "branches/{branchId}": {
      "schema": "Branch",
      "description": "IDI Branch offices"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Membership categories"
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "Conference and event information"
    }
  }
}
